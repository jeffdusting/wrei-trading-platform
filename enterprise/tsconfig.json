{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@enterprise/*": ["./*"],
      "@shared/lib/*": ["../lib/*"],
      "@shared/components/*": ["../components/*"],
      "@shared/design-system/*": ["../design-system/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../lib/**/*.ts",
    "../components/**/*.ts",
    "../components/**/*.tsx",
    "../design-system/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
