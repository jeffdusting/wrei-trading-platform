# WREI Trading Platform - Environment Variables Example
# Copy this to .env.local and fill in your API keys

# ================================
# CORE PLATFORM CONFIGURATION
# ================================

# Anthropic Claude API (Required for negotiation engine)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ================================
# LIVE DATA SOURCES (Optional)
# ================================

# Federal Reserve Economic Data (FRED)
# Free API key: https://fred.stlouisfed.org/docs/api/api_key.html
# Used for economic indicators affecting RWA markets
FRED_API_KEY=your_fred_api_key_here

# CoinMarketCap API
# Free tier: 10,000 calls/month
# Sign up: https://pro.coinmarketcap.com/account
# Used for RWA token market data
CMC_API_KEY=your_coinmarketcap_api_key_here

# World Bank API
# No API key required - free access
# Automatically used for commodity price indicators

# ================================
# FUTURE DATA SOURCES
# ================================

# Australian Clean Energy Regulator (CER)
# For NSW ESC pricing - API access TBD
# CER_API_KEY=your_cer_api_key_here

# LSEG (formerly Refinitiv) ESG Data
# Enterprise-grade carbon market data
# Contact LSEG for pricing and access
# LSEG_API_KEY=your_lseg_api_key_here
# LSEG_API_SECRET=your_lseg_api_secret_here

# ================================
# DATA SOURCE CONFIGURATION
# ================================

# Data refresh intervals (in milliseconds)
CARBON_PRICING_REFRESH=300000    # 5 minutes
RWA_MARKET_REFRESH=900000       # 15 minutes
ECONOMIC_DATA_REFRESH=3600000   # 1 hour

# API timeouts (in milliseconds)
API_TIMEOUT_DEFAULT=10000       # 10 seconds
API_TIMEOUT_EXTENDED=30000      # 30 seconds for complex queries

# Cache settings
ENABLE_DATA_CACHING=true
CACHE_TTL_SHORT=300000          # 5 minutes
CACHE_TTL_MEDIUM=900000         # 15 minutes
CACHE_TTL_LONG=3600000          # 1 hour

# ================================
# FALLBACK CONFIGURATION
# ================================

# Use simulation data when APIs fail
FALLBACK_TO_SIMULATION=true

# Minimum confidence threshold for live data
MIN_CONFIDENCE_THRESHOLD=60

# ================================
# DEVELOPMENT/TESTING
# ================================

# Use sandbox/test endpoints for development
USE_SANDBOX_APIS=false

# Enable detailed API logging
ENABLE_API_LOGGING=true

# Test API keys (for development)
TEST_CMC_API_KEY=b54bcf4d-1bca-4e8e-9a24-22ff2c3d462c  # CMC sandbox key